DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require

# Se o PHP/libpq for antigo e o Neon pedir endpoint ID, use:
# DATABASE_URL=postgresql://usuario:senha@ep-seu-endpoint.regiao.aws.neon.tech/neondb?sslmode=require&options=endpoint%3Dep-seu-endpoint

# Alternativa usando campos separados:
PGHOST=host-do-neon
PGPORT=5432
PGDATABASE=neondb
PGUSER=usuario
PGPASSWORD=senha
PGSSLMODE=require
PGOPTIONS=endpoint=ep-seu-endpoint

# IDs de usuarios que podem acessar endpoints em /admin.
ADMIN_USER_IDS=1
